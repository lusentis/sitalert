# Database (Neon PostgreSQL + PostGIS) — auto-injected by Vercel for web
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Redis (Upstash) — auto-injected by Vercel for web
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
# TCP connection for collector pub/sub (same Upstash instance)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# OpenAI (collector LLM classification)
OPENAI_API_KEY=sk-xxx

# Telegram (collector OSINT adapter)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abc123
TELEGRAM_SESSION_STRING=xxx

# NASA FIRMS (collector structured adapter)
NASA_FIRMS_API_KEY=xxx

# Nominatim (geocoding — default: public OSM, 1 req/sec)
NOMINATIM_URL=https://nominatim.openstreetmap.org
