{
  "name": "travelrisk",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@travelrisk/web",
    "dev:collector": "turbo run dev --filter=@travelrisk/collector",
    "start:web": "turbo run start --filter=@travelrisk/web",
    "start:collector": "turbo run start --filter=@travelrisk/collector",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@travelrisk/db",
    "db:push": "turbo run db:push --filter=@travelrisk/db",
    "db:migrate": "turbo run db:migrate --filter=@travelrisk/db",
    "db:studio": "turbo run db:studio --filter=@travelrisk/db",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
